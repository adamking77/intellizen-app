    "react-force-graph-2d": "^1.29.1",
    "react-grid-layout": "^2.2.3",
    "react-resizable": "^3.1.3",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
