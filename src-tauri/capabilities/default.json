{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$HOME/vault/**" }
      ]
    },
    "fs:default",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    "fs:allow-write-file",
    "fs:allow-create",
    "fs:allow-mkdir",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/vault" },
        { "path": "$HOME/vault/**/*" },
        { "path": "$HOME/vault/intelligence" },
        { "path": "$HOME/vault/intelligence/**/*" }
      ]
    },
    "shell:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "claude",
          "cmd": "claude",
          "args": ["-p", { "validator": "(?s)^.*$", "raw": true }, "--allowedTools", { "validator": ".*" }],
          "sidecar": false
        },
        {
          "name": "claude-home-local",
          "cmd": "$HOME/.local/bin/claude",
          "args": ["-p", { "validator": "(?s)^.*$", "raw": true }, "--allowedTools", { "validator": ".*" }],
          "sidecar": false
        },
        {
          "name": "claude-homebrew",
          "cmd": "/opt/homebrew/bin/claude",
          "args": ["-p", { "validator": "(?s)^.*$", "raw": true }, "--allowedTools", { "validator": ".*" }],
          "sidecar": false
        },
        {
          "name": "claude-usr-local",
          "cmd": "/usr/local/bin/claude",
          "args": ["-p", { "validator": "(?s)^.*$", "raw": true }, "--allowedTools", { "validator": ".*" }],
          "sidecar": false
        }
      ]
    }
  ]
}
